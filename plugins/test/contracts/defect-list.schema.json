{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DefectList",
  "description": "缺陷列表文件 schema (defect_list.json)。requirement-traceability 在 smoke-test 模式下产出，被 ai-case smoke_test workflow 消费。源真实样本：session 239。设计取舍：additionalProperties=true 允许 skill 演进加新字段；not.anyOf.required 是显式 ban 已知拼错（actual / expected / desc / title）的黑名单，不是穷举——发现新拼错模式时追加。",
  "type": "object",
  "required": ["defects"],
  "properties": {
    "defects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "priority"],
        "additionalProperties": true,
        "not": {
          "anyOf": [
            {"required": ["actual"]},
            {"required": ["expected"]},
            {"required": ["desc"]},
            {"required": ["title"]}
          ]
        },
        "properties": {
          "id": {
            "type": "string",
            "description": "缺陷 ID，如 DEFECT-1"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "缺陷名称（canonical 字段名，参见 requirement-traceability/TEMPLATES.md）。注意 schema 显式 ban `title`——尽管 JIRA / TAPD 等行业习惯用 title，marketplace 内部约定用 name，schema ban 是为了让规约可 enforce"
          },
          "priority": {
            "enum": ["P0", "P1", "P2"],
            "description": "缺陷优先级，requirement-traceability TEMPLATES.md 仅定义 P0-P2 判定规则"
          },
          "category": {
            "type": "string",
            "description": "缺陷类型，常见值：implementation_missing / logic_error / api_inconsistency / ui_deviation"
          },
          "description": {
            "type": "string",
            "description": "完整描述（注意是 description 不是 desc）"
          },
          "expected_result": {
            "type": "string",
            "description": "预期结果（注意是 expected_result 不是 expected）"
          },
          "actual_result": {
            "type": "string",
            "description": "实际结果（注意是 actual_result 不是 actual）"
          },
          "evidence": {
            "type": "object",
            "description": "证据元信息（来源、置信度、代码位置等）",
            "additionalProperties": true,
            "properties": {
              "source": {"type": "string"},
              "source_id": {"type": "string"},
              "requirement_ref": {"type": "string"},
              "code_location": {"type": "string"},
              "confidence": {"type": "number"}
            }
          },
          "related_mr": {
            "type": "string",
            "description": "关联 MR/PR 标识"
          },
          "related_test_case": {
            "type": "string",
            "description": "关联测试用例描述"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "by_priority": {
          "type": "object",
          "additionalProperties": {"type": "integer"}
        },
        "by_category": {
          "type": "object",
          "additionalProperties": {"type": "integer"}
        }
      }
    }
  },
  "additionalProperties": true
}
