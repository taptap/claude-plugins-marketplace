{
  "name": "taptap-plugins",
  "owner": {
    "name": "TapTap AI Team",
    "email": ""
  },
  "metadata": {
    "description": "TapTap Claude Code 插件库 - 提供开发工作流自动化插件",
    "version": "0.1.39",
    "pluginRoot": "./plugins"
  },
  "plugins": [
    {
      "name": "spec",
      "source": "./plugins/spec",
      "description": "Spec-Driven Development 插件，自动执行完整开发流程",
      "version": "0.1.4",
      "author": {
        "name": "TapTap AI Team"
      },
      "category": "productivity",
      "keywords": ["spec", "sdd"],
      "strict": true
    },
    {
      "name": "git",
      "source": "./plugins/git",
      "description": "Git 工作流命令插件，提供提交/推送/MR、远程平台操作、自动代码审查（Agent Team 审查+辩论 + Codex 双视角），支持项目自定义审查规则",
      "version": "0.1.13",
      "author": {
        "name": "TapTap AI Team"
      },
      "category": "version-control",
      "keywords": ["git", "commit", "review", "code-review", "agent-team"],
      "strict": true
    },
    {
      "name": "sync",
      "source": "./plugins/sync",
      "description": "项目配置同步插件，提供 MCP、LSP 和开发环境配置同步功能",
      "version": "0.1.23",
      "author": {
        "name": "TapTap AI Team"
      },
      "category": "productivity",
      "keywords": ["sync", "mcp", "lsp", "config"],
      "strict": true
    },
    {
      "name": "quality",
      "source": "./plugins/quality",
      "description": "代码质量插件，提供 AI 驱动的代码审查和质量检查功能，支持跨部门多语言（Go/Java/Python/Kotlin/Swift/TypeScript）",
      "version": "0.0.4",
      "author": {
        "name": "TapTap AI Team"
      },
      "category": "code-quality",
      "keywords": ["review", "quality", "bug-detection", "security", "performance"],
      "strict": true
    },
    {
      "name": "test",
      "source": "./plugins/test",
      "description": "QA 工作流插件，提供需求评审与澄清、测试用例生成（含冗余对评审）、用例评审、变更分析、代码级测试生成（单元/集成）、需求回溯（含冒烟测试模式）、Bug 修复分析等 QA 全流程 Skill",
      "version": "0.0.30",
      "author": {
        "name": "TapTap AI Team"
      },
      "category": "testing",
      "keywords": ["test", "qa", "unit-test", "integration-test", "test-case-generation", "test-review", "verification", "ui-fidelity"],
      "strict": true
    }
  ]
}
