# ============================================================
# Test Plugin - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Scripts auto-load this file via python-dotenv.
# Shell env vars take precedence over .env values.
# ============================================================

# ------------------------------------------------------------
# MeterSphere  (metersphere-sync skill)
# ------------------------------------------------------------
# Required - get from MeterSphere > Personal API Keys
MS_ACCESS_KEY=
MS_SECRET_KEY=

# MeterSphere instance config
MS_BASE_URL=https://metersphere.tapsvc.com
MS_PROJECT_ID=
MS_WORKSPACE_ID=
MS_DEFAULT_NODE_ID=
MS_PLAN_NODE_ID=
MS_DEFAULT_MAINTAINER=admin
MS_DEFAULT_STAGE=smoke

# MeterSphere custom field IDs (from your MeterSphere instance)
MS_FIELD_ID_MAINTAINER=
MS_FIELD_ID_PRIORITY=
MS_FIELD_ID_STATUS=
MS_FIELD_ID_AUTOMATED=

# ------------------------------------------------------------
# Feishu / Lark  (requirement-clarification, requirement-traceability)
# ------------------------------------------------------------
# Required - get from Feishu Open Platform > App Credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Optional - default: https://open.feishu.cn
# FEISHU_BASE_URL=https://open.feishu.cn

# ------------------------------------------------------------
# GitLab  (change-analysis, requirement-traceability)
# ------------------------------------------------------------
# Required if using GitLab
GITLAB_URL=https://git.tapsvc.com
GITLAB_TOKEN=

# Optional - set to false for self-signed certificates
# GITLAB_SSL_VERIFY=false

# Optional - JSON mapping: platform name -> project ID(s)
# Example: {"server": 2103, "android": 4252, "mini_game": [4191, 4218]}
# GITLAB_PROJECT_MAPPING=

# ------------------------------------------------------------
# GitHub  (change-analysis, requirement-traceability)
# ------------------------------------------------------------
# Required if using GitHub
# GITHUB_TOKEN=

# Optional - default: https://api.github.com (for GitHub Enterprise)
# GITHUB_URL=https://api.github.com

# Optional - JSON mapping: platform name -> repo(s)
# Example: {"server": ["org/repo-a"], "web": "org/repo-b"}
# GITHUB_REPO_MAPPING=
