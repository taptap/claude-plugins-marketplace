{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://taptap/agents-plugins/schemas/forward_verification.schema.json",
  "title": "forward_verification.json (v2)",
  "description": "requirement-traceability 正向通道（用例中介验证）的产出。每条记录对应一条用例的代码追踪结果。",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["case_id", "requirement_id", "result", "confidence"],
    "additionalProperties": true,
    "properties": {
      "case_id": {
        "type": "string",
        "minLength": 1,
        "description": "用例编号。来自上游 final_cases.json（如 M1-TC-01）；降级路径形如 FORWARD-TRACER-FP-1"
      },
      "requirement_id": {
        "type": "string",
        "pattern": "^FP-\\d+",
        "description": "对应的需求功能点编号（FP-N）"
      },
      "requirement_name": {
        "type": "string"
      },
      "result": {
        "enum": ["pass", "fail", "inconclusive"]
      },
      "confidence": {
        "type": ["number", "null"],
        "minimum": 0,
        "maximum": 100,
        "description": "0-100 置信度；降级模式（无代码可验证）时为 null"
      },
      "trace": {
        "type": "string",
        "description": "代码追踪路径（调用链格式）"
      },
      "expected": {
        "type": "string",
        "description": "用例 expected 原文摘录"
      },
      "actual": {
        "type": "string",
        "description": "代码追踪推断的实际行为；fail 必填"
      },
      "inconclusive_reason": {
        "type": ["string", "null"],
        "enum": [
          "call_depth_exceeded",
          "dynamic_dispatch",
          "external_dependency",
          "insufficient_context",
          "complex_logic",
          null
        ]
      },
      "source": {
        "type": "string",
        "description": "兜底标记，例如 synthesized_from_coverage_report"
      },
      "ms_id": {
        "type": "string",
        "description": "MeterSphere 用例 UUID。由 P3 writeback 在 lookup 后回写进 enriched fv，下次跑可跳过 lookup"
      },
      "evidence": {
        "type": "object",
        "required": ["code_location", "verification_logic"],
        "additionalProperties": false,
        "properties": {
          "code_location": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^.+:\\d+(-\\d+)?$",
              "description": "格式 file:line 或 file:start-end"
            }
          },
          "verification_logic": {
            "type": "string",
            "minLength": 1,
            "description": "为什么这条用例期望的行为，对应的代码确实做到了（或确实没做到）"
          },
          "considered_failure_modes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["mode", "ruled_out_by"],
              "additionalProperties": false,
              "properties": {
                "mode": {"type": "string", "minLength": 1},
                "ruled_out_by": {"type": "string", "minLength": 1}
              }
            },
            "description": "对抗式自检：列出考虑过但被排除的失败模式"
          },
          "human_override": {
            "type": "object",
            "required": ["from", "to", "reason"],
            "additionalProperties": false,
            "properties": {
              "from": {"enum": ["pass", "fail", "inconclusive"]},
              "to": {"enum": ["pass", "fail", "inconclusive"]},
              "reason": {"type": "string", "minLength": 1}
            },
            "description": "Phase 4.7 fail 复核被人工改判时的审计字段"
          }
        }
      },
      "external_dependencies": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "types": {
            "type": "array",
            "items": {
              "enum": [
                "device",
                "server",
                "third_party",
                "framework_default",
                "user_action",
                "data_state",
                "timing"
              ]
            }
          },
          "notes": {"type": "string"}
        },
        "description": "结构化标记验证依赖外部因素；types 非空时 P6 状态映射会把 pass 降级为 MS Prepare"
      }
    },
    "allOf": [
      {
        "if": {"properties": {"result": {"const": "fail"}}, "required": ["result"]},
        "then": {
          "anyOf": [
            {"required": ["actual", "evidence"]},
            {"properties": {"source": {"const": "synthesized_from_coverage_report"}},
             "required": ["source"]}
          ]
        }
      },
      {
        "if": {"properties": {"result": {"const": "inconclusive"}}, "required": ["result"]},
        "then": {"required": ["inconclusive_reason"]}
      },
      {
        "if": {
          "properties": {"result": {"const": "pass"}},
          "required": ["result"]
        },
        "then": {
          "anyOf": [
            {"required": ["evidence"]},
            {"properties": {"source": {"const": "synthesized_from_coverage_report"}},
             "required": ["source"]}
          ]
        }
      },
      {
        "if": {
          "properties": {
            "result": {"const": "pass"},
            "confidence": {"type": "number", "minimum": 85}
          },
          "required": ["result", "confidence"]
        },
        "then": {
          "anyOf": [
            {"properties": {"evidence": {"required": ["considered_failure_modes"]}},
             "required": ["evidence"]},
            {"properties": {"source": {"const": "synthesized_from_coverage_report"}},
             "required": ["source"]}
          ]
        }
      },
      {
        "not": {
          "properties": {
            "result": {"const": "pass"},
            "confidence": {"type": "number", "maximum": 69}
          },
          "required": ["result", "confidence"]
        }
      }
    ]
  }
}
